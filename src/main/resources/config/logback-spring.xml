<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="appName" source="spring.application.name"/>

    <!-- JSON appender for structured logging -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{correlationId}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Production: simple logging (activate with spring.profiles.active=prod) -->
    <springProfile name="prod">
        <root level="WARN">
            <appender-ref ref="STDOUT"/>
        </root>
    </springProfile>

    <!-- Default (dev / test) -->
    <springProfile name="!prod">
        <root level="INFO">
            <appender-ref ref="STDOUT"/>
        </root>
        <logger name="com.example.productcatalog" level="DEBUG"/>
    </springProfile>
</configuration>
