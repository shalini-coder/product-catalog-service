# ─────────────────────────────────────────────────────────────────────────────
# Azure environment variables template
#
# Copy this file to .env.azure.local  and fill in real values.
# .env.azure.local is in .gitignore — never commit real credentials.
#
# Usage:
#   Windows PowerShell :  Get-Content .env.azure.local | ForEach-Object { $n,$v=$_ -split '=',2; Set-Item "env:$n" $v }
#   Linux / macOS      :  export $(cat .env.azure.local | xargs)
#   IntelliJ / VS Code :  paste into Run Configuration → Environment variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Spring profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local-azure

# ── Azure Key Vault (optional for local dev) ──────────────────────────────────
AZURE_KEYVAULT_ENABLED=false
AZURE_KEYVAULT_ENDPOINT=https://<your-vault-name>.vault.azure.net/
# For Service Principal auth (local dev only):
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-app-registration-client-id>
AZURE_CLIENT_SECRET=<your-app-registration-client-secret>

# ── Azure PostgreSQL Flexible Server ─────────────────────────────────────────
# Find in: Azure Portal → PostgreSQL Flexible Server → Overview → Server name
AZURE_POSTGRES_HOST=<server-name>
AZURE_POSTGRES_DB=productcatalog
AZURE_POSTGRES_USER=<admin-username>
AZURE_POSTGRES_PASSWORD=<admin-password>

# Full JDBC URL (used in azure profile directly)
SPRING_DATASOURCE_URL=jdbc:postgresql://<server-name>.postgres.database.azure.com:5432/productcatalog?sslmode=require
SPRING_DATASOURCE_USERNAME=<admin-username>
SPRING_DATASOURCE_PASSWORD=<admin-password>

# ── Couchbase Capella ──────────────────────────────────────────────────────────
# Find in: Capella UI → Cluster → Connect tab → Connection string
# Always use the couchbases:// scheme (TLS enforced)
AZURE_COUCHBASE_HOST=<cluster-id>.dp.cloud.couchbase.com
AZURE_COUCHBASE_BUCKET=product-catalog
AZURE_COUCHBASE_USERNAME=<database-user>
AZURE_COUCHBASE_PASSWORD=<database-password>

# Full connection string (used in azure profile)
SPRING_COUCHBASE_CONNECTION_STRING=couchbases://<cluster-id>.dp.cloud.couchbase.com
SPRING_COUCHBASE_USERNAME=<database-user>
SPRING_COUCHBASE_PASSWORD=<database-password>
SPRING_COUCHBASE_BUCKET_NAME=product-catalog

# ── Azure Event Hubs (Kafka-compatible) ───────────────────────────────────────
# Find in: Azure Portal → Event Hubs Namespace → Shared Access Policies → RootManageSharedAccessKey
AZURE_EVENTHUB_NAMESPACE=<eventhub-namespace-name>
AZURE_EVENTHUB_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=<key>
AZURE_EVENTHUB_CONSUMER_GROUP=$Default

# ── Application Insights ──────────────────────────────────────────────────────
# Find in: Azure Portal → Application Insights → Overview → Connection String
AZURE_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/
AZURE_APPINSIGHTS_INSTRUMENTATION_KEY=<instrumentation-key>

# ── JWT Secret ────────────────────────────────────────────────────────────────
APP_JWT_SECRET=<at-least-64-character-random-string-for-hs512>

# ── Azure Container Registry ──────────────────────────────────────────────────
ACR_NAME=<registry-name>
ACR_LOGIN_SERVER=<registry-name>.azurecr.io
